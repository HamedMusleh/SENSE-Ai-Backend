# Copy to .env and adjust. Loaded by your shell / process manager.
SENSE_HOST=127.0.0.1
SENSE_PORT=8000
# real | mock | hybrid
SENSE_PIPELINE_MODE=hybrid
SENSE_DEBUG=true
SENSE_MAX_UPLOAD_MB=25
SENSE_PIPELINE_TIMEOUT=120
SENSE_SESSION_TTL_MIN=60
SENSE_CORS_ORIGINS=*
# Needed only when SENSE_PIPELINE_MODE uses the real OpenAI-based engine:
# OPENAI_API_KEY=sk-...
